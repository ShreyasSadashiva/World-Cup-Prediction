# Path to your Firebase service account key JSON (from Firebase Console → Project Settings → Service Accounts)
FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccountKey.json

# Or paste the JSON content directly (useful for cloud deployment):
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

FOOTBALL_DATA_API_KEY=your-free-api-key-from-football-data.org
